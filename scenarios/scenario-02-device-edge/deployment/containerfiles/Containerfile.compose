# Containerfile for packaging Podman Compose manifest as OCI image
# This creates a minimal OCI image containing only the compose manifest
# FlightCtl agent will extract and use this manifest to deploy the MLOps stack

FROM scratch

# Copy the compose manifest
# FlightCtl expects the file to be named 'podman-compose.yaml'
COPY compose/podman-compose.yaml /podman-compose.yaml

# Metadata labels for image identification
LABEL org.opencontainers.image.title="MLOps GPU Stack Compose Manifest"
LABEL org.opencontainers.image.description="Podman Compose manifest for deploying model-car, vLLM, and OpenWebUI"
LABEL org.opencontainers.image.vendor="Red Hat Emerging Technologies"
LABEL org.opencontainers.image.source="https://github.com/your-org/mlops-flightctl-gitops"
LABEL app.type="compose"
LABEL app.runtime="podman"
